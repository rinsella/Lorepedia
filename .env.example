# Lorepedia.net environment
NODE_ENV=development
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lorepedia

# Superadmin (used by seed script — change immediately after first login)
SUPERADMIN_EMAIL=admin@lorepedia.net
SUPERADMIN_PASSWORD=ChangeThisImmediately123!

# Storage
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=./uploads
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Email
EMAIL_PROVIDER=none
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Captcha (none|turnstile|hcaptcha|recaptcha)
CAPTCHA_PROVIDER=none
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# Rate limit / cache
RATE_LIMIT_DRIVER=database
REDIS_URL=

# Feature flags
PUBLIC_DEMO_WORLD_ENABLED=true
MAINTENANCE_MODE=false
